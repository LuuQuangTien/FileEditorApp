@startuml
left to right direction
actor "User" as user
actor "PdfConvert/CloudConvert Service" as pdf_service <<External System>>
actor "Local Storage" as local_storage <<Device>>

package "PDF Tools Module" {
  usecase "Convert File to PDF" as UC_ToPdf
  usecase "Convert PDF to File" as UC_PdfTo
  usecase "Merge Multiple PDFs" as UC_Merge
  usecase "Split PDF" as UC_Split
  usecase "Annotate/Highlight PDF" as UC_Annotate
  usecase "Save Final PDF" as UC_Save
}

user --> UC_ToPdf
user --> UC_PdfTo
user --> UC_Merge
user --> UC_Split
user --> UC_Annotate

UC_ToPdf --> pdf_service : "Gọi API chuyển đổi (vd: CloudConvert)"
UC_PdfTo --> pdf_service

UC_Merge ..> UC_Save : <<include>>
UC_Split ..> UC_Save : <<include>>
UC_Annotate ..> UC_Save : <<include>>

UC_Save --> local_storage
@enduml
