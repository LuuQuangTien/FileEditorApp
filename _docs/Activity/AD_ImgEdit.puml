@startuml
title Activity Diagram: Image Editing Operations

start

:User selects Image Tool;

:Open corresponding Activity;
:Launch PhotoPicker;
:Select image from gallery;
:Load Bitmap and display preview;

switch (Editing Tool)

case (Crop)
  :Adjust aspect ratio and size;
  :ImageService.cropBitmap();

case (Rotate / Flip)
  :Rotate or flip image;
  :ImageService.applyTransformations();

case (Filters)
  :Select filter preset;
  :Adjust brightness/contrast/saturation;
  :ImageService.applyFilters();

case (Enhance)
  :Show processing overlay;
  :ImageService.applyEnhancement();
  :Display enhanced result;

endswitch

:Update image preview;

if (Save image?) then (Yes)
  :ImageService.saveBitmapToGallery();
  :Save PNG using MediaStore API;
  :Show success message;

elseif (Reset image?) then (Reset)
  :Restore original image;

else (Exit)
  :Close Activity;

endif

stop
@enduml