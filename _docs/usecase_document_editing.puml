@startuml
left to right direction
actor "User" as user
actor "Local File System" as lfs <<System>>

package "Document Editing Module" {
  usecase "Open Document (Word/Excel)" as UC_Open
  usecase "Edit Text Content" as UC_EditText
  usecase "Format Text" as UC_Format
  usecase "Edit Cell/Formula (Excel)" as UC_EditCell
  usecase "Save Changes" as UC_Save
  usecase "Export to PDF" as UC_ExportPdf
}

user --> UC_Open
user --> UC_EditText
user --> UC_Format
user --> UC_EditCell
user --> UC_Save
user --> UC_ExportPdf

UC_Open --> lfs
UC_Save --> lfs

UC_EditText ..> UC_Save : <<include>>
UC_EditCell ..> UC_Save : <<include>>
@enduml
