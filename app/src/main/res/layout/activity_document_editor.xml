<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:orientation="vertical">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@color/white">

            <!-- Top Bar: Back + Actions -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:paddingHorizontal="12dp"
                android:paddingTop="12dp"
                android:paddingBottom="8dp">

                <ImageView
                    android:id="@+id/btn_back"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_arrow_left"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <View
                    android:layout_width="0dp"
                    android:layout_height="0dp"
                    android:layout_weight="1" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/btn_save"
                    style="?attr/materialButtonOutlinedStyle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Save"
                    android:textSize="12sp"
                    app:icon="@drawable/ic_save"
                    app:iconSize="16dp"
                    app:cornerRadius="8dp"
                    android:layout_marginEnd="8dp" />

                <ImageView
                    android:id="@+id/btn_more"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_more_vertical"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>

            <!-- Document Title -->
            <TextView
                android:id="@+id/tv_doc_title"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:text="Project Proposal.docx"
                android:textSize="18sp"
                android:textStyle="bold"
                android:textColor="@color/black"
                android:paddingHorizontal="16dp"
                android:paddingBottom="12dp"
                android:maxLines="1"
                android:ellipsize="end" />
        </LinearLayout>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/neutral_200" />

        <!-- Formatting Toolbar -->
        <HorizontalScrollView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:scrollbars="none"
            android:background="@color/white">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="8dp"
                android:gravity="center_vertical">

                <ImageView
                    android:id="@+id/btn_bold"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_bold"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <ImageView
                    android:id="@+id/btn_italic"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_italic"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <ImageView
                    android:id="@+id/btn_underline"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_underline"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/neutral_200"
                    android:layout_marginHorizontal="4dp" />

                <ImageView
                    android:id="@+id/btn_align_left"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_align_left"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <ImageView
                    android:id="@+id/btn_align_center"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_align_center"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <ImageView
                    android:id="@+id/btn_align_right"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_align_right"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/neutral_200"
                    android:layout_marginHorizontal="4dp" />

                <ImageView
                    android:id="@+id/btn_list"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_list"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <ImageView
                    android:id="@+id/btn_list_ordered"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_list_ordered"
                    android:background="?attr/selectableItemBackgroundBorderless" />

                <!-- Divider -->
                <View
                    android:layout_width="1dp"
                    android:layout_height="24dp"
                    android:background="@color/neutral_200"
                    android:layout_marginHorizontal="4dp" />

                <ImageView
                    android:id="@+id/btn_insert_image"
                    android:layout_width="36dp"
                    android:layout_height="36dp"
                    android:padding="6dp"
                    android:src="@drawable/ic_image"
                    android:background="?attr/selectableItemBackgroundBorderless" />
            </LinearLayout>
        </HorizontalScrollView>

        <View
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:background="@color/neutral_200" />

        <!-- Editor Text Area -->
        <EditText
            android:id="@+id/et_editor"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_weight="1"
            android:gravity="top|start"
            android:background="@null"
            android:padding="16dp"
            android:textSize="16sp"
            android:lineSpacingExtra="4dp"
            android:textColor="@color/black"
            android:hint="Start typing..."
            android:text="This is a sample document. You can edit this text and use AI features to improve your writing.\n\nClick the AI button to get writing assistance, grammar corrections, and content suggestions." />
    </LinearLayout>

    <!-- AI Assistant FAB -->
    <FrameLayout
        android:id="@+id/fab_ai"
        android:layout_width="56dp"
        android:layout_height="56dp"
        android:layout_gravity="bottom|end"
        android:layout_marginEnd="16dp"
        android:layout_marginBottom="16dp"
        android:background="@drawable/bg_gradient_ai_fab"
        android:elevation="6dp"
        android:clickable="true"
        android:focusable="true">
        <ImageView
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:layout_gravity="center"
            android:src="@drawable/ic_sparkles"
            app:tint="@color/white" />
    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>
